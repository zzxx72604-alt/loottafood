/* You can add global styles to this file, and also import other style files */
@import url("https://fonts.googleapis.com/css2?family=Quicksand&display=swap");

*{
  box-sizing: border-box;
}

html{
  font-size:16px;
}

html,
button{
  font-family: "Quicksand", "sans-serif";
}

body{
  margin: 0;
  background: #ffffff;
  color: #222222;
  transition: background 0.25s ease, color 0.25s ease;
}

a{
  text-decoration: none;
}

/* ============ DARK MODE ============ */
body.dark-theme{
  background: #15171c;
  color: #e8e8ea;
}

body.dark-theme app-header header{
  background: #1d2027;
  border-bottom-color: #ff5a5a;
}
body.dark-theme app-header a{
  color: #ff8a8a;
}
body.dark-theme app-header a:hover{
  background: #ff5a5a;
  color: #15171c;
}
body.dark-theme app-header .theme-toggle{
  color: #e8e8ea;
}
body.dark-theme app-header .menu{
  background: #2a2e37;
}

body.dark-theme app-home li a,
body.dark-theme app-favorites-page li a{
  background: #1d2027;
  border-color: #2a2e37;
  color: #ff8a8a;
}
body.dark-theme app-home .origins span,
body.dark-theme app-favorites-page .origins span{
  background: #2a2e37;
  color: #b9b9c0;
}
body.dark-theme app-home .price,
body.dark-theme app-favorites-page .price{
  background: #1d2027;
  color: #e8e8ea;
}

body.dark-theme app-tags a{
  color: #ff8a8a;
}
body.dark-theme app-search input{
  background: #1d2027;
  color: #e8e8ea;
  border-color: #2a2e37;
}
body.dark-theme app-search button{
  background: #ff5a5a;
  color: #15171c;
  border: none;
}

body.dark-theme app-food-page .details,
body.dark-theme app-food-page .container{
  color: #e8e8ea;
}
body.dark-theme app-food-page .tags a{
  background: #2a2e37;
  color: #ff8a8a;
}
body.dark-theme app-food-page button{
  background: #ff5a5a;
  color: #15171c;
}

body.dark-theme input,
body.dark-theme select,
body.dark-theme textarea{
  background: #1d2027;
  color: #e8e8ea;
  border-color: #2a2e37;
}

/* Payment options (dark mode) */
body.dark-theme payment-options .method,
body.dark-theme payment-options .pay-card{
  background: #1d2027;
  border-color: #2a2e37;
  color: #e8e8ea;
}
body.dark-theme payment-options .m-note,
body.dark-theme payment-options .ref,
body.dark-theme payment-options .scan-text{
  color: #b9b9c0;
}
