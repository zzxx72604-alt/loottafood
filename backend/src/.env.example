# Copy this file to ".env" (same folder) and fill in your values.
#
# LOCAL MongoDB (needs MongoDB installed on the machine):
# MONGO_URI=mongodb://localhost:27017/foodmine
#
# CLOUD MongoDB Atlas (works on any machine, no install needed):
# Paste your Atlas string and add the database name (/foodmine) before the "?".
# Example:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/foodmine?retryWrites=true&w=majority

MONGO_URI=mongodb://localhost:27017/foodmine
JWT_SECRET=somesecretkey123
PORT=5000
